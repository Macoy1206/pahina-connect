<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Pahina Connect - Library Management System</display-name>

    <!-- Default welcome page -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- Auth Filter -->
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.pahinaconnect.filter.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/student/*</url-pattern>
    </filter-mapping>

    <!-- Servlets -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.pahinaconnect.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.pahinaconnect.servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.pahinaconnect.servlet.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ForgotPasswordServlet</servlet-name>
        <servlet-class>com.pahinaconnect.servlet.ForgotPasswordServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ForgotPasswordServlet</servlet-name>
        <url-pattern>/forgot-password</url-pattern>
    </servlet-mapping>

    <!-- Admin Servlets -->
    <servlet>
        <servlet-name>AdminDashboardServlet</servlet-name>
        <servlet-class>com.pahinaconnect.servlet.admin.AdminDashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminDashboardServlet</servlet-name>
        <url-pattern>/admin/dashboard</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>BookServlet</servlet-name>
        <servlet-class>com.pahinaconnect.servlet.admin.BookServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BookServlet</servlet-name>
        <url-pattern>/admin/books</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CategoryServlet</servlet-name>
        <servlet-class>com.pahinaconnect.servlet.admin.CategoryServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CategoryServlet</servlet-name>
        <url-pattern>/admin/categories</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AuthorServlet</servlet-name>
        <servlet-class>com.pahinaconnect.servlet.admin.AuthorServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AuthorServlet</servlet-name>
        <url-pattern>/admin/authors</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>IssueBookServlet</servlet-name>
        <servlet-class>com.pahinaconnect.servlet.admin.IssueBookServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>IssueBookServlet</servlet-name>
        <url-pattern>/admin/issue-book</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ReturnBookServlet</servlet-name>
        <servlet-class>com.pahinaconnect.servlet.admin.ReturnBookServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReturnBookServlet</servlet-name>
        <url-pattern>/admin/return-book</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>StudentManageServlet</servlet-name>
        <servlet-class>com.pahinaconnect.servlet.admin.StudentManageServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StudentManageServlet</servlet-name>
        <url-pattern>/admin/students</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AnalyticsServlet</servlet-name>
        <servlet-class>com.pahinaconnect.servlet.admin.AnalyticsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AnalyticsServlet</servlet-name>
        <url-pattern>/admin/analytics</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminChangePasswordServlet</servlet-name>
        <servlet-class>com.pahinaconnect.servlet.admin.AdminChangePasswordServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminChangePasswordServlet</servlet-name>
        <url-pattern>/admin/change-password</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ProfileImageServlet</servlet-name>
        <servlet-class>com.pahinaconnect.servlet.ProfileImageServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProfileImageServlet</servlet-name>
        <url-pattern>/uploads/profiles/*</url-pattern>
    </servlet-mapping>

    <!-- Student Servlets -->
    <servlet>
        <servlet-name>StudentDashboardServlet</servlet-name>
        <servlet-class>com.pahinaconnect.servlet.student.StudentDashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StudentDashboardServlet</servlet-name>
        <url-pattern>/student/dashboard</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>StudentProfileServlet</servlet-name>
        <servlet-class>com.pahinaconnect.servlet.student.StudentProfileServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StudentProfileServlet</servlet-name>
        <url-pattern>/student/profile</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>FinePaymentServlet</servlet-name>
        <servlet-class>com.pahinaconnect.servlet.student.FinePaymentServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>FinePaymentServlet</servlet-name>
        <url-pattern>/student/fine-payment</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>StudentBooksServlet</servlet-name>
        <servlet-class>com.pahinaconnect.servlet.student.StudentBooksServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StudentBooksServlet</servlet-name>
        <url-pattern>/student/my-books</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>StudentChangePasswordServlet</servlet-name>
        <servlet-class>com.pahinaconnect.servlet.student.StudentChangePasswordServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StudentChangePasswordServlet</servlet-name>
        <url-pattern>/student/change-password</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>BorrowRequestServlet</servlet-name>
        <servlet-class>com.pahinaconnect.servlet.BorrowRequestServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BorrowRequestServlet</servlet-name>
        <url-pattern>/borrow-request</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>BorrowRequestManageServlet</servlet-name>
        <servlet-class>com.pahinaconnect.servlet.admin.BorrowRequestManageServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BorrowRequestManageServlet</servlet-name>
        <url-pattern>/admin/borrow-requests</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SearchServlet</servlet-name>
        <servlet-class>com.pahinaconnect.servlet.SearchServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SearchServlet</servlet-name>
        <url-pattern>/search</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>QRCodeServlet</servlet-name>
        <servlet-class>com.pahinaconnect.servlet.QRCodeServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>QRCodeServlet</servlet-name>
        <url-pattern>/qrcode</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>EbookServlet</servlet-name>
        <servlet-class>com.pahinaconnect.servlet.EbookServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EbookServlet</servlet-name>
        <url-pattern>/ebook</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ReminderServlet</servlet-name>
        <servlet-class>com.pahinaconnect.servlet.admin.ReminderServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReminderServlet</servlet-name>
        <url-pattern>/admin/reminders</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ReservationServlet</servlet-name>
        <servlet-class>com.pahinaconnect.servlet.ReservationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReservationServlet</servlet-name>
        <url-pattern>/reserve</url-pattern>
    </servlet-mapping>

    <!-- Session timeout: 30 minutes -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- Error pages -->
    <error-page>
        <error-code>404</error-code>
        <location>/error/404.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/error/500.jsp</location>
    </error-page>

</web-app>
